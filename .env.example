# SpiritCore — Environment Variables Reference
# Copy this file to .env for local development.
# For production (Railway), set these in the Railway dashboard under Variables.
# DO NOT commit .env to version control.

# ─── REQUIRED (all environments) ────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── REQUIRED (production only — enforced by validateConfig()) ───────────────
NODE_ENV=production
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
API_KEY=sk_live_your_secret_api_key_here

# ─── SERVER ──────────────────────────────────────────────────────────────────
# Railway injects PORT automatically. Do not set this manually in Railway.
PORT=3005

# ─── CORS ────────────────────────────────────────────────────────────────────
# Restrict to your frontend domain in production
# CORS_ORIGIN=https://your-frontend-domain.com

# ─── ADAPTER ─────────────────────────────────────────────────────────────────
# Use "local" for template-based responses (no LLM cost).
# Use "openai" to enable GPT-4o-mini responses.
ADAPTER_MODE=local

# Required only if ADAPTER_MODE=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Set LOG_PRETTY=true for local development (human-readable logs)
# LOG_PRETTY=true

# ─── MEMORY POLICY ───────────────────────────────────────────────────────────
MEMORY_DORMANT_DAYS=30
MEMORY_DELETE_AFTER_DAYS=730
MEMORY_COMPRESS_AFTER_DAYS=365

# ─── RATE LIMITING (optional tuning) ─────────────────────────────────────────
RATE_LIMIT_MAX=120
RATE_LIMIT_TIME_WINDOW_MS=60000
ADAPTER_RATE_LIMIT_MAX=30

# ─── TIMEOUTS (optional tuning, milliseconds) ────────────────────────────────
# ADAPTER_TIMEOUT_MS=30000
# ORCHESTRATOR_TIMEOUT_MS=45000
# DB_QUERY_TIMEOUT_MS=8000
