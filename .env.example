# SpiritCore - Environment Variables Reference
# Copy this file to .env for local development.
# For production (Railway), set these in the Railway dashboard under Variables.
# DO NOT commit .env to version control.

# Required for backend startup
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Runtime mode
NODE_ENV=development
# Railway injects PORT automatically. Local default is 3005.
PORT=3005

# Optional backend behavior flags
USE_LLM=false
DEBUG=false

# Admin / operational route protection
# ADMIN_AUTH_MODE:
#   auto    -> bypass locally, enforce in production
#   enforce -> always require admin credentials
#   off     -> always bypass (not recommended for production)
ADMIN_AUTH_MODE=auto
# Preferred admin credential for protected routes
# Supported headers: x-admin-key, x-api-key, or Authorization: Bearer <key>
# ADMIN_API_KEY=replace-with-a-long-random-secret

# CORS
# Leave unset to allow all origins through the current Fastify CORS config.
# Set to true, false, a single origin, or a comma-separated allowlist.
# CORS_ORIGIN=https://your-frontend-domain.com
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# Adapter selection
# Use "local" for template-based responses with no external LLM dependency.
# Use "openai" to enable OpenAI-backed generation paths.
ADAPTER_MODE=local

# Required when ADAPTER_MODE is not "local"
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Spiritkins generator providers
# Image generation: configure one Flux path, with optional Leonardo fallback.
# Preferred local/self-hosted path:
# FLUX_COMFYUI_BASE_URL=http://127.0.0.1:8188
# FLUX_COMFYUI_API_KEY=
# FLUX_COMFYUI_WORKFLOW_PATH=config/flux-comfyui-workflow.json
# FLUX_COMFYUI_MODEL=flux-dev

# Alternative hosted Flux API path:
# FLUX_API_URL=https://your-flux-provider.example.com
# FLUX_API_KEY=your-flux-api-key
# FLUX_API_MODEL=flux-dev
# FLUX_API_GENERATE_PATH=/v1/images/generate
# FLUX_API_STATUS_PATH=/v1/images/generate

# Optional Leonardo fallback for image generation:
# LEONARDO_API_URL=https://cloud.leonardo.ai/api/rest
# LEONARDO_API_KEY=your-leonardo-api-key
# LEONARDO_MODEL=leonardo-diffusion-xl
# LEONARDO_STYLE_PRESET=SPIRITVERSE_PREMIUM

# Video generation via Runway:
# RUNWAY_API_URL=https://api.dev.runwayml.com
# RUNWAY_API_KEY=your-runway-api-key
# RUNWAY_API_VERSION=2024-11-06
# RUNWAY_MODEL=gen3a_turbo
# RUNWAY_GENERATE_PATH=/v1/video/generate
# RUNWAY_EXTEND_PATH=/v1/video/extend
# RUNWAY_STATUS_PATH=/v1/tasks

# Logging
LOG_LEVEL=info
# Set LOG_PRETTY=true for local development (human-readable logs)
LOG_PRETTY=true

# Memory policy
MEMORY_DORMANT_DAYS=30
MEMORY_DELETE_AFTER_DAYS=730
MEMORY_COMPRESS_AFTER_DAYS=365

# Rate limiting (optional tuning)
RATE_LIMIT_MAX=120
RATE_LIMIT_TIME_WINDOW_MS=60000
ADAPTER_RATE_LIMIT_MAX=30

# Timeouts (optional tuning, milliseconds)
# ADAPTER_TIMEOUT_MS=30000
# ORCHESTRATOR_TIMEOUT_MS=45000
# DB_QUERY_TIMEOUT_MS=8000

# Optional / legacy compatibility
# The current backend startup path does not require these values.
# Keep them only if another deployment surface still depends on them.
# SUPABASE_ANON_KEY=your-supabase-anon-key
# API_KEY=legacy-api-key-if-still-used-elsewhere-or-as-temporary-admin-fallback
